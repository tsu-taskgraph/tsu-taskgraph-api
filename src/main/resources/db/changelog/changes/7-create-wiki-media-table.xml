<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">


    <changeSet id="1781854998679-1" author="Administrator">
        <createTable tableName="wiki_media">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_wiki_media"/>
            </column>
            <column name="project_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="filename" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="original_filename" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="mime_type" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="size_bytes" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="url" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="uploaded_by" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME"/>
        </createTable>
    </changeSet>
    <changeSet id="1781854998679-2" author="Administrator">
        <addForeignKeyConstraint baseColumnNames="project_id" baseTableName="wiki_media"
                                 constraintName="FK_WIKI_MEDIA_ON_PROJECT" referencedColumnNames="id"
                                 referencedTableName="projects"/>
    </changeSet>
    <changeSet id="1781854998679-3" author="Administrator">
        <addForeignKeyConstraint baseColumnNames="uploaded_by" baseTableName="wiki_media"
                                 constraintName="FK_WIKI_MEDIA_ON_UPLOADED_BY" referencedColumnNames="id"
                                 referencedTableName="users"/>
    </changeSet>
</databaseChangeLog>