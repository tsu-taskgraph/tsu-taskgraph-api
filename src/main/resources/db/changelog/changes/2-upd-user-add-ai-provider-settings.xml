<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-5.0.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1781333355130-1" author="Administrator">
        <createTable tableName="ai_provider_settings">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_ai_provider_settings"/>
            </column>
            <column name="temperature" type="DOUBLE"/>
            <column name="max_tokens" type="INT"/>
            <column name="thinking_budget" type="INT"/>
            <column name="enable_web_search" type="BOOLEAN"/>
            <column name="extended_thinking" type="BOOLEAN"/>
            <column name="thinking_token_budget" type="INT"/>
            <column name="reasoning_effort" type="VARCHAR(255)"/>
            <column name="groq_reasoning_format" type="VARCHAR(255)"/>
            <column name="ollama_num_ctx" type="INT"/>
            <column name="ollama_num_gpu" type="INT"/>
        </createTable>
    </changeSet>
    <changeSet id="1781333355130-2" author="Administrator">
        <createTable tableName="ai_settings">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_ai_settings"/>
            </column>
            <column name="provider" type="VARCHAR(255)"/>
            <column name="model" type="VARCHAR(255)"/>
            <column name="encrypted_api_key" type="VARCHAR(255)"/>
            <column name="api_key_masked" type="VARCHAR(255)"/>
            <column name="ollama_base_url" type="VARCHAR(255)"/>
            <column name="provider_settings_id" type="UUID"/>
        </createTable>
    </changeSet>
    <changeSet id="1781333355130-3" author="Administrator">
        <addColumn tableName="users">
            <column name="ai_settings_id" type="UUID"/>
        </addColumn>
    </changeSet>
    <changeSet id="1781333355130-4" author="Administrator">
        <addUniqueConstraint columnNames="provider_settings_id" constraintName="uc_ai_settings_provider_settings"
                             tableName="ai_settings"/>
    </changeSet>
    <changeSet id="1781333355130-5" author="Administrator">
        <addUniqueConstraint columnNames="ai_settings_id" constraintName="uc_users_ai_settings" tableName="users"/>
    </changeSet>
    <changeSet id="1781333355130-6" author="Administrator">
        <addForeignKeyConstraint baseColumnNames="provider_settings_id" baseTableName="ai_settings"
                                 constraintName="FK_AI_SETTINGS_ON_PROVIDER_SETTINGS" referencedColumnNames="id"
                                 referencedTableName="ai_provider_settings"/>
    </changeSet>
    <changeSet id="1781333355130-7" author="Administrator">
        <addForeignKeyConstraint baseColumnNames="ai_settings_id" baseTableName="users"
                                 constraintName="FK_USERS_ON_AI_SETTINGS" referencedColumnNames="id"
                                 referencedTableName="ai_settings"/>
    </changeSet>
</databaseChangeLog>